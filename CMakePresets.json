{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-vs2022-x64",
      "displayName": "Windows VS 2022 x64",
      "description": "Generates a Visual Studio 2022 x64 solution using vcpkg for dependencies",
      "binaryDir": "${sourceDir}/build",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-vs2022-x64-debug",
      "displayName": "Windows VS 2022 x64 (Debug)",
      "inherits": "windows-vs2022-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "windows-vs2022-x64",
      "configuration": "Release"
    },
    {
      "name": "debug",
      "configurePreset": "windows-vs2022-x64-debug",
      "configuration": "Debug"
    }
  ]
}
